@model IT15_LabExam.Models.Employee
@{
    ViewData["Title"] = "Delete Employee";
}

<div class="row justify-content-center">
    <div class="col-md-6">
        <div class="card shadow-sm border-danger">
            <div class="card-header bg-danger text-white">
                <h4 class="mb-0">🗑️ Delete Employee</h4>
            </div>
            <div class="card-body">
                <div class="alert alert-warning">
                    Are you sure you want to delete this employee? All associated payroll records will also be deleted.
                </div>
                <dl class="row">
                    <dt class="col-sm-4">Employee ID</dt>
                    <dd class="col-sm-8">@Model.EmployeeId</dd>
                    <dt class="col-sm-4">Full Name</dt>
                    <dd class="col-sm-8">@Model.FullName</dd>
                    <dt class="col-sm-4">Position</dt>
                    <dd class="col-sm-8">@Model.Position</dd>
                    <dt class="col-sm-4">Department</dt>
                    <dd class="col-sm-8">@Model.Department</dd>
                    <dt class="col-sm-4">Daily Rate</dt>
                    <dd class="col-sm-8">₱@Model.DailyRate.ToString("N2")</dd>
                </dl>
                <form asp-action="Delete">
                    <input type="hidden" asp-for="EmployeeId" />
                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-danger">Yes, Delete</button>
                        <a asp-action="Index" class="btn btn-secondary">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
