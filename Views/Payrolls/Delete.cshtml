@model IT15_LabExam.Models.Payroll
@{
    ViewData["Title"] = "Delete Payroll";
}

<div class="row justify-content-center">
    <div class="col-md-6">
        <div class="card shadow-sm border-danger">
            <div class="card-header bg-danger text-white">
                <h4 class="mb-0">🗑️ Delete Payroll Record</h4>
            </div>
            <div class="card-body">
                <div class="alert alert-warning">Are you sure you want to delete this payroll record?</div>
                <dl class="row">
                    <dt class="col-sm-4">Payroll ID</dt>
                    <dd class="col-sm-8">@Model.PayrollId</dd>
                    <dt class="col-sm-4">Employee</dt>
                    <dd class="col-sm-8">@Model.Employee?.FullName</dd>
                    <dt class="col-sm-4">Date</dt>
                    <dd class="col-sm-8">@Model.Date.ToString("MMM dd, yyyy")</dd>
                    <dt class="col-sm-4">Days Worked</dt>
                    <dd class="col-sm-8">@Model.DaysWorked</dd>
                    <dt class="col-sm-4">Gross Pay</dt>
                    <dd class="col-sm-8 text-success fw-bold">₱@Model.GrossPay.ToString("N2")</dd>
                    <dt class="col-sm-4">Deduction</dt>
                    <dd class="col-sm-8 text-danger">₱@Model.Deduction.ToString("N2")</dd>
                    <dt class="col-sm-4">Net Pay</dt>
                    <dd class="col-sm-8 text-primary fw-bold">₱@Model.NetPay.ToString("N2")</dd>
                </dl>
                <form asp-action="Delete">
                    <input type="hidden" asp-for="PayrollId" />
                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-danger">Yes, Delete</button>
                        <a asp-action="Index" asp-route-employeeId="@Model.EmployeeId" class="btn btn-secondary">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
